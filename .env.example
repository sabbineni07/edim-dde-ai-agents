# EDIM DDE AI Agents - Environment Configuration
# Copy to .env: cp .env.example .env

# Azure OpenAI (required for real LLM)
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_API_KEY=your-api-key-here
# AZURE_OPENAI_ACCESS_TOKEN=  # for Azure AD / az login
AZURE_OPENAI_API_VERSION=2024-05-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Azure AI Search (optional - for RAG)
AZURE_SEARCH_ENDPOINT=https://YOUR-SEARCH.search.windows.net
AZURE_SEARCH_API_KEY=your-search-api-key-here
AZURE_SEARCH_INDEX_NAME=recommendations-index

# Local mode (use sample CSV instead of Databricks)
USE_LOCAL_DATA=true

# Database
USE_POSTGRES=true
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=ai_agents

# Databricks (when USE_LOCAL_DATA=false)
# DATABRICKS_SERVER_HOSTNAME=adb-xxxx.azuredatabricks.net
# DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxx
# DATABRICKS_TOKEN=your-databricks-token
# DATABRICKS_JOB_CLUSTER_METRICS_TABLE=your_catalog.your_schema.job_cluster_metrics_aggregated
